{
  "name": "@devtent/desktop",
  "version": "1.4.0",
  "description": "DevTent",
  "license": "LicenseRef-DTCL-1.0",
  "author": {
    "name": "DevTent Contributors",
    "email": "support@devtent.dev"
  },
  "homepage": "https://github.com/DubStepMad/devtent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DubStepMad/devtent.git"
  },
  "bugs": {
    "url": "https://github.com/DubStepMad/devtent/issues"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json && node scripts/build-preload.mjs && npm run generate-icons && npm run copy-assets",
    "copy-assets": "node scripts/copy-assets.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "start": "node scripts/dev.mjs",
    "dev": "node scripts/dev.mjs",
    "start:once": "npm run build && electron .",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "pack": "npm run build && node scripts/ensure-eb-nsis.cjs && electron-builder --dir",
    "dist": "npm run build && node scripts/run-dist.cjs",
    "screenshots": "node scripts/capture-screenshots.mjs"
  },
  "dependencies": {
    "@devtent/core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "playwright": "^1.52.0",
    "pngjs": "^7.0.0",
    "to-ico": "^1.1.5",
    "typescript": "^5.8.2"
  },
  "build": {
    "appId": "dev.devtent.app",
    "productName": "DevTent",
    "publish": null,
    "icon": "assets/icon.png",
    "afterPack": "scripts/after-pack.cjs",
    "electronVersion": "35.7.5",
    "electronLanguages": ["en-US"],
    "npmRebuild": false,
    "asar": true,
    "compression": "normal",
    "copyright": "Copyright © 2026 DevTent Contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.{map,d.ts}",
      "!dist/**/*.d.ts.map",
      "!dist/ui/screenshot*",
      "!dist/manifests/**",
      "!dist/templates/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "dist/manifests", "to": "manifests" },
      { "from": "dist/templates", "to": "templates" },
      { "from": "assets/icon.png", "to": "assets/icon.png" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "legalTrademarks": "DevTent Contributors",
      "signAndEditExecutable": true,
      "artifactName": "DevTent Setup ${version}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "DevTent-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "artifactName": "DevTent-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DevTent",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "build/installer.nsh"
    }
  }
}
